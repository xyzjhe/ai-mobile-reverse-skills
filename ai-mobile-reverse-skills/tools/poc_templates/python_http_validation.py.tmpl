#!/usr/bin/env python3
"""
Minimal authorized-only validation template.

Replace every PLACEHOLDER_* value before running.
Do not use against production targets.
"""

import json
from typing import Dict, Any

import requests


URL = "https://PLACEHOLDER_TEST_HOST/PATH"
METHOD = "POST"
TIMEOUT = 10

HEADERS: Dict[str, str] = {
    "Authorization": "Bearer PLACEHOLDER_TOKEN",
    "Content-Type": "application/json",
}

BODY: Dict[str, Any] = {
    "field": "PLACEHOLDER_VALUE"
}


def mutate_payload(payload: Dict[str, Any]) -> Dict[str, Any]:
    """
    Apply the minimal authorized validation change here.
    Keep the change scoped to one field whenever possible.
    """
    mutated = dict(payload)
    mutated["field"] = "PLACEHOLDER_MUTATED_VALUE"
    return mutated


def maybe_rebuild_signature(
    payload: Dict[str, Any],
    headers: Dict[str, str],
) -> None:
    """
    TODO:
    Rebuild sign/data fields here if Phase 3/4 already restored the logic.
    If no signing is required, leave this function unchanged.
    """
    return None


def main() -> None:
    baseline = dict(BODY)
    mutated = mutate_payload(baseline)
    request_headers = dict(HEADERS)
    maybe_rebuild_signature(mutated, request_headers)

    print("[*] Sending minimal validation request")
    print(json.dumps({"url": URL, "method": METHOD, "body": mutated}, ensure_ascii=False, indent=2))

    response = requests.request(
        METHOD,
        URL,
        headers=request_headers,
        json=mutated,
        timeout=TIMEOUT,
    )

    print("[*] Status:", response.status_code)
    print("[*] Response:")
    print(response.text[:4000])


if __name__ == "__main__":
    main()
