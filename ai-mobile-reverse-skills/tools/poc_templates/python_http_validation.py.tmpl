#!/usr/bin/env python3
"""
Minimal authorized-only validation template.

Replace every PLACEHOLDER_* value before running.
Do not use against production targets.
"""

import json
import sys
from pathlib import Path
from typing import Dict, Any

import requests

# sign_rebuilder import — adjust path to your scripts directory
_SCRIPTS_DIR = Path(__file__).resolve().parent.parent / "scripts"
if str(_SCRIPTS_DIR) not in sys.path:
    sys.path.insert(0, str(_SCRIPTS_DIR))


URL = "https://PLACEHOLDER_TEST_HOST/PATH"
METHOD = "POST"
TIMEOUT = 10

HEADERS: Dict[str, str] = {
    "Authorization": "Bearer PLACEHOLDER_TOKEN",
    "Content-Type": "application/json",
}

BODY: Dict[str, Any] = {
    "field": "PLACEHOLDER_VALUE"
}


def mutate_payload(payload: Dict[str, Any]) -> Dict[str, Any]:
    """
    Apply the minimal authorized validation change here.
    Keep the change scoped to one field whenever possible.
    """
    mutated = dict(payload)
    mutated["field"] = "PLACEHOLDER_MUTATED_VALUE"
    return mutated


def maybe_rebuild_signature(
    payload: Dict[str, Any],
    headers: Dict[str, str],
) -> None:
    """
    Rebuild sign/data fields if Phase 3/4 already restored the signing logic.

    Fill in SIGN_CONFIG with the algorithm, key, field_order from
    crypto_native_analysis.json / vuln_analysis.json.
    See sign_rebuilder.py --example for config templates.

    If no signing is required, leave SIGN_CONFIG as None.
    """
    SIGN_CONFIG = None
    # Example:
    # SIGN_CONFIG = {
    #     "algorithm": "hmac_sha256",
    #     "key": "PLACEHOLDER_SECRET",
    #     "sign_field": "sign",
    #     "field_order": ["timestamp", "data", "nonce"],
    #     "separator": "&",
    #     "key_value_fmt": "key=value",
    #     "append_key": True,
    # }

    if SIGN_CONFIG:
        from sign_rebuilder import apply_sign
        apply_sign(SIGN_CONFIG, payload, headers=headers)
    return None


def main() -> None:
    baseline = dict(BODY)
    mutated = mutate_payload(baseline)
    request_headers = dict(HEADERS)
    maybe_rebuild_signature(mutated, request_headers)

    print("[*] Sending minimal validation request")
    print(json.dumps({"url": URL, "method": METHOD, "body": mutated}, ensure_ascii=False, indent=2))

    response = requests.request(
        METHOD,
        URL,
        headers=request_headers,
        json=mutated,
        timeout=TIMEOUT,
    )

    print("[*] Status:", response.status_code)
    print("[*] Response:")
    print(response.text[:4000])


if __name__ == "__main__":
    main()
